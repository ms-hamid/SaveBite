{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "framework": "nextjs",

  "installCommand": "npm install --workspace=frontend",
  "buildCommand":   "npm run build --workspace=frontend",
  "outputDirectory": "frontend/.next",
  "devCommand":     "npm run dev --workspace=frontend",

  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- frontend/",

  "rewrites": [
    {
      "source": "/api/core/:path*",
      "destination": "https://your-backend-core.railway.app/:path*"
    },
    {
      "source": "/api/ai/:path*",
      "destination": "https://your-backend-ai.railway.app/api/v1/:path*"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",            "value": "DENY" },
        { "key": "X-XSS-Protection",          "value": "1; mode=block" },
        { "key": "Referrer-Policy",            "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",         "value": "geolocation=(self), camera=(self)" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
