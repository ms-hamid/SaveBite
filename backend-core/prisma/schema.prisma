generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["auth", "public"]
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model AuthUser {
  instance_id                 String?                @db.Uuid
  id                          String                 @id @db.Uuid
  aud                         String?                @db.VarChar(255)
  role                        String?                @db.VarChar(255)
  email                       String?                @db.VarChar(255)
  encrypted_password          String?                @db.VarChar(255)
  email_confirmed_at          DateTime?              @db.Timestamptz(6)
  invited_at                  DateTime?              @db.Timestamptz(6)
  confirmation_token          String?                @db.VarChar(255)
  confirmation_sent_at        DateTime?              @db.Timestamptz(6)
  recovery_token              String?                @db.VarChar(255)
  recovery_sent_at            DateTime?              @db.Timestamptz(6)
  email_change_token_new      String?                @db.VarChar(255)
  email_change                String?                @db.VarChar(255)
  email_change_sent_at        DateTime?              @db.Timestamptz(6)
  last_sign_in_at             DateTime?              @db.Timestamptz(6)
  raw_app_meta_data           Json?
  raw_user_meta_data          Json?
  is_super_admin              Boolean?
  createdAt                   DateTime?              @map("created_at") @db.Timestamptz(6)
  updated_at                  DateTime?              @db.Timestamptz(6)
  phone                       String?                @unique
  phone_confirmed_at          DateTime?              @db.Timestamptz(6)
  phone_change                String?                @default("")
  phone_change_token          String?                @default("") @db.VarChar(255)
  phone_change_sent_at        DateTime?              @db.Timestamptz(6)
  confirmed_at                DateTime?              @default(dbgenerated("LEAST(email_confirmed_at, phone_confirmed_at)")) @db.Timestamptz(6)
  email_change_token_current  String?                @default("") @db.VarChar(255)
  email_change_confirm_status Int?                   @default(0) @db.SmallInt
  banned_until                DateTime?              @db.Timestamptz(6)
  reauthentication_token      String?                @default("") @db.VarChar(255)
  reauthentication_sent_at    DateTime?              @db.Timestamptz(6)
  is_sso_user                 Boolean                @default(false)
  deleted_at                  DateTime?              @db.Timestamptz(6)
  is_anonymous                Boolean                @default(false)
  identities                  identities[]
  mfa_factors                 mfa_factors[]
  oauth_authorizations        oauth_authorizations[]
  oauth_consents              oauth_consents[]
  one_time_tokens             one_time_tokens[]
  sessions                    sessions[]
  webauthn_challenges         webauthn_challenges[]
  webauthn_credentials        webauthn_credentials[]
  admin                       Admin?
  customer                    Customer?
  device_tokens               device_tokens[]
  listings                    Listing[]
  merchant                    Merchant?
  password_reset_otps         PasswordResetOtp[]
  payments                    Payment[]
  profile                     Profile?

  @@index([instance_id])
  @@index([is_anonymous])
  @@map("users")
  @@schema("auth")
}

model Merchant {
  merchant_name             String?              @db.VarChar(70)
  latitude                  Float?
  longitude                 Float?
  kyc_status                kyc_status?          @default(pending)
  google_map_url            String?
  virtual_balance           Decimal?             @db.Decimal(8, 2)
  address                   String?
  bank_name                 String?              @db.VarChar(50)
  bank_account              String?              @db.VarChar(20)
  user_id                   String               @id @default(dbgenerated("auth.uid()")) @db.Uuid
  category                  String?              @db.VarChar
  desc                      String?
  pickup_instruction        String?
  contactless_pickup        Boolean              @default(false)
  notify_staff_upon_arrival Boolean              @default(false)
  pickup_open               DateTime?            @db.Time(6)
  pickup_close              DateTime?            @db.Time(6)
  same_day_pickup           Boolean              @default(false)
  max_prep_time             BigInt?
  rating                    Float?               @db.Real
  rating_times              BigInt               @default(0)
  profile_pic               String?
  ai_feature_history        ai_feature_history[]
  listings                  Listing[]
  auth_user                 AuthUser             @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders                    Order[]
  withdrawals               Withdrawal[]

  @@map("merchants")
  @@schema("public")
}

model Customer {
  full_name    String   @db.VarChar(50)
  exp          Int?     @default(0)
  strike_count Int?     @default(0)
  user_id      String   @id @default(dbgenerated("auth.uid()")) @db.Uuid
  auth_user    AuthUser @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orders       Order[]

  @@map("customers")
  @@schema("public")
}

model Admin {
  last_login  DateTime?    @db.Timestamptz(6)
  user_id     String       @id @default(dbgenerated("auth.uid()")) @db.Uuid
  auth_user   AuthUser     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  withdrawals Withdrawal[]

  @@map("admins")
  @@schema("public")
}

model Listing {
  id                  BigInt               @id(map: "listing_pkey") @default(autoincrement())
  name                String?              @db.VarChar(50)
  open_time           DateTime?            @db.Timestamptz(6)
  close_time          DateTime?            @db.Timestamptz(6)
  sold_total          Int                  @default(0)
  stock_total         Int
  description         String?
  is_open             Boolean?
  original_price      Decimal?             @db.Decimal(10, 2)
  discount_price      Decimal?             @db.Decimal(10, 2)
  discount_percentage Int?
  deleted_at          DateTime?            @db.Timestamptz(6)
  merchant_id         String?              @default(dbgenerated("auth.uid()")) @db.Uuid
  img_url             String?
  public_id           String               @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status              listing_status       @default(close)
  ai_feature_history  ai_feature_history[]
  user                AuthUser?            @relation(fields: [merchant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  merchant            Merchant?            @relation(fields: [merchant_id], references: [user_id], onDelete: Cascade, map: "listings_merchant_id_fkey1")
  orders              Order[]

  @@map("listings")
  @@schema("public")
}

model Order {
  id                    BigInt        @id @default(autoincrement())
  qty                   Int
  total_amount          Decimal       @db.Decimal(10, 2)
  qr_token              String?
  status                order_status? @default(pending_payment)
  created_at            DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?     @default(now()) @db.Timestamptz(6)
  deleted_at            DateTime?     @db.Timestamptz(6)
  listing_id            BigInt
  public_id             String        @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchant_id           String        @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id           String        @default(dbgenerated("auth.uid()")) @db.Uuid
  order_code            String?       @db.Char(6)
  order_code_expires_at DateTime?     @db.Timestamptz(6)
  order_code_active     Boolean       @default(false)
  order_lock_expired    DateTime?     @db.Timestamptz(6)
  listing               Listing       @relation(fields: [listing_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_listing_order")
  customer              Customer      @relation(fields: [customer_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  merchant              Merchant      @relation(fields: [merchant_id], references: [user_id], onDelete: Cascade)
  payments              Payment[]

  @@map("orders")
  @@schema("public")
}

model Payment {
  id              BigInt     @id @default(autoincrement())
  amount          Decimal?   @db.Decimal(10, 2)
  midtrans_trx_id String?    @db.VarChar(50)
  pg_status       pg_status? @default(pending)
  time_limit      DateTime   @db.Timestamptz(6)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime   @default(now()) @db.Timestamptz(6)
  order_id        BigInt
  customer_id     String?    @default(dbgenerated("auth.uid()")) @db.Uuid
  payment_method  String?
  expired_at      DateTime?  @db.Timestamptz(6)
  paid_at         DateTime?  @db.Timestamptz(6)
  qris_url        String?
  redirected_url  String?
  auth_user       AuthUser?  @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order           Order      @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("payments")
  @@schema("public")
}

model Profile {
  user_id   String   @id @default(dbgenerated("auth.uid()")) @db.Uuid
  full_name String?  @db.VarChar
  role      role     @default(CUSTOMER)
  auth_user AuthUser @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviews   Review[]

  @@map("profiles")
  @@schema("public")
}

model Review {
  id          BigInt   @id @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  img_url     String?
  rating      Int      @default(5) @db.SmallInt
  review      DateTime @db.Date
  merchant_id String   @default(dbgenerated("auth.uid()")) @db.Uuid
  profile     Profile  @relation(fields: [merchant_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@map("reviews")
  @@schema("public")
}

model Withdrawal {
  id          BigInt          @id @default(autoincrement())
  created_at  DateTime        @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?       @default(now()) @db.Timestamptz(6)
  merchant_id String          @default(dbgenerated("auth.uid()")) @db.Uuid
  admin_id    String?         @db.Uuid
  status      withdraw_status @default(pending)
  amount      Decimal         @default(0) @db.Decimal
  qty         BigInt          @default(0)
  admin       Admin?          @relation(fields: [admin_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  merchant    Merchant        @relation(fields: [merchant_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "withdrawals_customer_id_fkey")

  @@map("withdrawals")
  @@schema("public")
}

model PasswordResetOtp {
  id            BigInt    @id @default(autoincrement())
  user_id       String    @db.Uuid
  otp_hash      String
  attempt_count Int       @default(0)
  expires_at    DateTime
  used_at       DateTime?
  created_at    DateTime  @default(now())
  user          AuthUser  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("password_reset_otps")
  @@schema("public")
}

