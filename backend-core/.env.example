# ─────────────────────────────────────────────────────────────────────────────
# SaveBite backend-core — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env for local development.
# On Railway/Render/VPS: set all vars via the platform's secret manager.
# Never commit a real .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
# Container platforms (Railway, Render) inject PORT automatically.
# Default: 5000 for local dev.
PORT=5000
NODE_ENV=production

# CORS: set to the Vercel frontend URL in production
FRONTEND_URL=https://your-app.vercel.app

# ─── Database ─────────────────────────────────────────────────────────────────
# Use a managed PostgreSQL service (Supabase, Neon, Railway Postgres, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Minimum 64 bytes. Store as a secret — never log or expose this value.
JWT_SECRET=your-very-long-random-secret-here-min-64-bytes

# ─── Supabase (server-side admin operations only) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Midtrans ─────────────────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
# Set to true when going live with real transactions
MIDTRANS_IS_PRODUCTION=false

# ─── AI Service (backend-ai FastAPI) ──────────────────────────────────────────
# Local dev:   http://localhost:8000
# Production:  https://your-backend-ai.railway.app  (or Render, VPS, etc.)
AI_SERVICE_URL=https://your-backend-ai.railway.app

# ─── Redis ────────────────────────────────────────────────────────────────────
# Use a managed Redis service (Railway Redis, Upstash, etc.) in production
REDIS_URL=redis://localhost:6379