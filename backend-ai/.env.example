# ─────────────────────────────────────────────────────────────────────────────
# SaveBite backend-ai — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env for local development.
# On Railway/Render/VPS: set all vars via the platform's secret manager.
# Never commit a real .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Values: "development" | "production"
# In production, /docs (Swagger UI) is hidden for security.
ENVIRONMENT=production

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL via asyncpg driver (Supabase, Neon, Railway Postgres, etc.)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/savebite

# ─── Backend Core Integration ─────────────────────────────────────────────────
# Used for internal service-to-service calls (e.g., order confirmations)
# Local dev:   http://localhost:5000
# Production:  https://your-backend-core.railway.app
BACKEND_CORE_URL=https://your-backend-core.railway.app

# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed origins.
# Must include the production Vercel frontend URL.
ALLOWED_ORIGINS=["https://your-app.vercel.app","https://your-backend-core.railway.app"]

# ─── ML Model Cache ───────────────────────────────────────────────────────────
# Directory where trained Prophet/XGBoost models are persisted (joblib).
# On containers: use a mounted volume path for persistence across restarts.
MODEL_CACHE_DIR=./data/processed

# ─── Server Binding (Uvicorn) ─────────────────────────────────────────────────
# HOST and PORT are consumed directly by the Dockerfile CMD / Procfile.
# Container platforms (Railway, Render) inject PORT automatically.
HOST=0.0.0.0
PORT=8000
